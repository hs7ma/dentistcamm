# ══════════════════════════════════════════════
#  DentistCam Backend — متغيرات البيئة
#  انسخ هذا الملف إلى .env وعدّل القيم
# ══════════════════════════════════════════════

# ── أمان ───────────────────────────────────────
# Token سري يُستخدم لمصادقة الكاميرا عبر WebSocket
CAMERA_TOKEN=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET

# ── OpenAI ─────────────────────────────────────
# مفتاح OpenAI للتحليل بـ GPT-4o Vision
# في الوضع السحابي، المفتاح يُخزّن هنا فقط (لا يُرسل للمتصفح)
OPENAI_API_KEY=sk-proj-...

# ── السيرفر ────────────────────────────────────
# Railway يضبط PORT تلقائياً — لا تغيّره يدوياً
PORT=8000