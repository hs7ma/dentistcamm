# ══════════════════════════════════════════════
#  DentistCam Frontend — متغيرات البيئة
#  انسخ هذا الملف إلى .env وعدّل القيم
# ══════════════════════════════════════════════

# ── صيغة التشغيل ────────────────────────────
# "local" = اتصال مباشر بكاميرا ESP32 (الافتراضي)
# "cloud" = اتصال عبر خادم Railway
VITE_MODE=local

# ── IP الكاميرا (الوضع المحلي فقط) ──────────
# اتركه فارغاً إذا أردت إدخاله من الواجهة
VITE_CAMERA_IP=172.20.10.10

# ── مفتاح OpenAI (الوضع المحلي فقط) ─────────
# في الوضع السحابي، المفتاح يُخزّن على السيرفر فقط
VITE_OPENAI_API_KEY=sk-proj-...